# ===== Xendit =====
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxx
XENDIT_WEBHOOK_VERIFICATION_TOKEN=your_webhook_verification_token_here

# ===== URLs =====
# Base URL of your frontend (used for Xendit redirect URLs)
FRONTEND_URL=http://localhost:5173

# Base URL of this backend server
BACKEND_URL=http://localhost:3001

# ===== Server =====
PORT=3001

# ===== JWT =====
JWT_SECRET=change-this-to-a-long-random-string

# ===== Appwrite (Server — requires API key with Databases read scope) =====
# Create an API key in Appwrite Console → Settings → API Keys
# Scopes needed: databases.read
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_server_api_key
APPWRITE_DATABASE_ID=photobooth_db
APPWRITE_COLLECTION_PROFILES=profiles
APPWRITE_COLLECTION_SUBSCRIPTIONS=subscriptions
